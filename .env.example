# Discord Bot Token (get from https://discord.com/developers/applications)
BOT_TOKEN=your-discord-bot-token-here

# ID of the voice channel the bot should always listen in
VOICE_CHANNEL_ID=your-voice-channel-id

# ID of the text channel where transcriptions will be posted
TEXT_CHANNEL_ID=your-text-channel-id

# Optional: Discord user/bot ID to ping with each transcription
# ADA_BOT_ID=your-bot-or-user-id
